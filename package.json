{
  "name": "c3-platform",
  "private": true,
"workspaces": [
  "packages/runtime-sdk",
  "packages/c3",
  "packages/c3-runtime",
  "packages/c3-spfx-host"
],
  "scripts": {
    "build:c3": "npm --workspace packages/c3 run build",
    "build:c3-runtime": "npm --workspace packages/c3 run build:runtime",
    "copy:c3-runtime": "node scripts/copy-c3-runtime.mjs",
    "build:c3-runtime-pkg": "npm --workspace packages/c3-runtime run build",
    "build:embedded": "npm run build:c3 && npm run build:c3-runtime-pkg && npm run copy:c3-runtime && npm run build:spfx",
    "lint:c3": "npm --workspace packages/c3 run lint",
    "build:spfx": "npm --workspace packages/c3-spfx-host run build",
    "start:spfx": "npm --workspace packages/c3-spfx-host run start"
  }
}