{
  "name": "@c3web/backup",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "C3 staging encrypted logical backup + restore job (Railway cron). Isolated from the API runtime.",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "backup": "tsx src/main.ts",
    "restore": "tsx src/restore-main.ts",
    "bootstrap-role": "tsx scripts/bootstrap-backup-role.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@c3web/persistence": "*",
    "pg": "^8.22.0",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "age-encryption": "^0.2.1",
    "typescript": "^5.9.0",
    "vitest": "^2.1.8"
  }
}
