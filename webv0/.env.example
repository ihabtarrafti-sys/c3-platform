# C3 Web V0 — environment template. Copy to `.env` for local dev.
# Validated at process start by @c3web/api (packages env schema). Missing or
# malformed values fail closed (the process refuses to start).

# ── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
LOG_LEVEL=info

# ── Database ───────────────────────────────────────────────────────────────
# Two DISTINCT roles. The API connects ONLY as the least-privileged app role
# (RLS-enforced). Migrations/admin use the privileged role. Never share them.
#
# Application role (RLS applies; cannot bypass tenant isolation):
DATABASE_URL=postgres://c3_app:c3_app_dev_pw@localhost:5432/c3web
# Privileged migration/admin role (owns schema, runs migrations; NEVER given
# to a production API process — env validation fails closed if it is):
DATABASE_ADMIN_URL=postgres://c3_admin:c3_admin_dev_pw@localhost:5432/c3web
# SELECT-only membership-resolution role (the production API's directory):
DATABASE_AUTH_URL=postgres://c3_auth:c3_auth_dev_pw@localhost:5432/c3web

# Trust X-Forwarded-* headers ONLY behind an explicitly known proxy boundary.
TRUST_PROXY=false

# ── Authentication ─────────────────────────────────────────────────────────
# Provider selection at the auth boundary. `dev` enables the signed
# development-only test IdP; it is HARD-DISABLED when NODE_ENV=production.
AUTH_PROVIDER=dev
# HS256 secret for the dev test IdP ONLY (never used in production).
DEV_AUTH_SECRET=dev-only-insecure-signing-secret-change-me

# Entra ID (OIDC) — boundary configuration. Not required for local automated
# tests; real values are supplied only in staging/production by the owner.
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_ISSUER=
ENTRA_JWKS_URI=
ENTRA_AUDIENCE=

# ── Web ────────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:4000
# Browser auth provider: dev (local/E2E) or entra (staging/production).
VITE_AUTH_PROVIDER=dev
# Entra SPA settings (staging/production builds only):
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_TENANT_ID=
VITE_ENTRA_API_SCOPE=
